// =====================================================
// CONTRATOS
// =====================================================

enum SituacaoContrato {
  RASCUNHO
  ATIVO
  SUSPENSO
  ENCERRADO
}

enum TipoReajuste {
  IGPM
  IPCA
  INCC
  NF
  NENHUM
}

model Contrato {
  id              String           @id @default(cuid()) @map("_id")
  empresaId       String
  clienteId       String
  numero          String
  descricao       String?
  dataInicio      DateTime
  dataFim         DateTime?
  valor           Decimal          @default(0) @db.Decimal(12, 2)
  tipoReajuste    TipoReajuste     @default(NENHUM)
  periodicidade   String           @default("MENSAL")
  status          SituacaoContrato @default(RASCUNHO)
  observacoes     String?
  dataCriacao     DateTime         @default(now())
  dataAtualizacao DateTime         @updatedAt

  empresa  Empresa           @relation(fields: [empresaId], references: [id])
  cliente  Cliente           @relation(fields: [clienteId], references: [id])
  medicoes ContratoMedicao[]

  @@unique([empresaId, numero])
  @@map("contratos")
}

model ContratoMedicao {
  id             String   @id @default(cuid()) @map("_id")
  contratoId     String
  periodo        String // "2026-07"
  valor          Decimal  @default(0) @db.Decimal(12, 2)
  dataVencimento DateTime
  status         String   @default("PENDENTE") // PENDENTE, FATURADO, CANCELADO
  pedidoGerado   String?
  dataCriacao    DateTime @default(now())

  contrato Contrato @relation(fields: [contratoId], references: [id], onDelete: Cascade)

  @@map("contrato_medicoes")
}

// =====================================================
// GARANTIAS
// =====================================================

model Garantia {
  id              String    @id @default(cuid()) @map("_id")
  empresaId       String
  clienteId       String
  produtoId       String
  vendaId         String?
  numero          String
  tipo            String    @default("FABRICA") // FABRICA, ESTENDIDA, LEGAL
  prazoDias       Int
  dataInicio      DateTime
  dataFim         DateTime?
  cobertura       String? // Descrição do que cobre
  status          String    @default("ATIVA") // ATIVA, EXPIRADA, CANCELADA, ACIONADA
  observacoes     String?
  dataCriacao     DateTime  @default(now())
  dataAtualizacao DateTime  @updatedAt

  empresa Empresa @relation(fields: [empresaId], references: [id])
  cliente Cliente @relation(fields: [clienteId], references: [id])
  produto Produto @relation(fields: [produtoId], references: [id])

