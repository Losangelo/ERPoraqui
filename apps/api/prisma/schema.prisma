  VAN
  CAMINHAO
  BICICLETA
  OUTRO
}

enum TipoTaxaEntrega {
  FIXA
  POR_KM
  POR_CEP
  POR_VALOR
}

enum TipoMotorista {
  PROPRIO
  PJ
}

model Motorista {
