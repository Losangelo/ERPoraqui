model VeiculoEntrega {
  id                String   @id @default(cuid()) @map("_id")
  empresaId         String
  placa             String
  marca             String?
  modelo            String?
  ano               Int?
  cor               String?
  capacidadeKg      Float?
  tipo              TipoVeiculo @default(CARRO)
  proprietarioId    String?
  ativo             Boolean  @default(true)
  observacoes       String?
  dataCriacao       DateTime @default(now())
  dataAtualizacao   DateTime @updatedAt

  empresa           Empresa   @relation(fields: [empresaId], references: [id])
  entregas          Entrega[]

  @@unique([empresaId, placa])
  @@map("veiculos_entrega")
}

model TaxaEntrega {
  id                String         @id @default(cuid()) @map("_id")
  empresaId         String
  descricao         String
  tipo              TipoTaxaEntrega @default(FIXA)
  valor             Float
  raioKm            Float?
  cepInicio         String?
  cepFim            String?
  valorMinimoPedido Float?
  ativo             Boolean        @default(true)
  dataCriacao       DateTime       @default(now())
  dataAtualizacao   DateTime       @updatedAt

  empresa           Empresa   @relation(fields: [empresaId], references: [id])
  entregas          Entrega[]

  @@map("taxas_entrega")
}

model Entrega {
  id                String          @id @default(cuid()) @map("_id")
  empresaId         String
  filialId          String
  pedidoVendaId     String?
  clienteId         String?
  motoristaId       String?
  veiculoId         String?
  transportadoraId  String?
  tokenRastreio     String          @unique @default(cuid())
  situacao          SituacaoEntrega @default(PENDENTE)
  enderecoEntrega   Json?
  dataAgendamento   DateTime?
  dataSaida         DateTime?
  dataEntrega       DateTime?
  dataPrevisao      DateTime?
  valorFrete        Float           @default(0)
  taxaEntregaId     String?
  observacoes       String?
  comprovanteUrl    String?
  assinaturaDigital String?
  dataCriacao       DateTime        @default(now())
  dataAtualizacao   DateTime        @updatedAt

  empresa           Empresa           @relation(fields: [empresaId], references: [id])
  filial            Filial            @relation(fields: [filialId], references: [id])
  pedidoVenda       PedidoVenda?      @relation(fields: [pedidoVendaId], references: [id])
  cliente           Cliente?          @relation(fields: [clienteId], references: [id])
  motorista         Motorista?        @relation(fields: [motoristaId], references: [id])
  veiculoEntrega    VeiculoEntrega?   @relation(fields: [veiculoId], references: [id])
  transportadora    Transportadora?   @relation(fields: [transportadoraId], references: [id])
  taxaEntrega       TaxaEntrega?      @relation(fields: [taxaEntregaId], references: [id])
  tentativas        EntregaTentativa[]
  avaliacao         Avaliacao?

  @@map("entregas")
}

model EntregaTentativa {
  id              String   @id @default(cuid()) @map("_id")
  entregaId       String
  dataTentativa   DateTime @default(now())
  motivoFalha     String?
  observacoes     String?
  dataCriacao     DateTime @default(now())

  entrega         Entrega  @relation(fields: [entregaId], references: [id], onDelete: Cascade)

  @@map("entregas_tentativas")
}

model Avaliacao {
  id              String   @id @default(cuid()) @map("_id")
  empresaId       String
  entregaId       String   @unique
  tokenAvaliacao  String   @unique @default(cuid())
  ratingLoja      Int?
  ratingPedido    Int?
  ratingEntrega   Int?
  comentario      String?
  dataCriacao     DateTime @default(now())

  empresa         Empresa  @relation(fields: [empresaId], references: [id])
  entrega         Entrega  @relation(fields: [entregaId], references: [id], onDelete: Cascade)

  @@map("avaliacoes")
}
