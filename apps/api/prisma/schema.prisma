// =====================================================
// CONCILIAÇÃO BANCÁRIA
// =====================================================

model ContaBancaria {
  id              String            @id @default(cuid()) @map("_id")
  empresaId       String
  banco           String
  agencia         String
  conta           String
  tipo            TipoContaBancaria @default(CORRENTE)
  saldoInicial    Float             @default(0)
  saldoAtual      Float             @default(0)
  ativo           Boolean           @default(true)
  dataCriacao     DateTime          @default(now())
  dataAtualizacao DateTime          @updatedAt

  empresa       Empresa                @relation(fields: [empresaId], references: [id])
  conciliacoes  Conciliacao[]
  movimentacoes MovimentacaoBancaria[]
  cheques       Cheque[]

  @@unique([empresaId, banco, agencia, conta])
  @@map("contas_bancarias")
}

model MovimentacaoBancaria {
  id               String                @id @default(cuid()) @map("_id")
  contaBancariaId  String
  dataMovimentacao DateTime
  dataCompetencia  DateTime?
  tipo             TipoMovimentoBancario
  descricao        String
  documento        String?
  valor            Float
  conciliado       Boolean               @default(false)
  conciliacaoId    String?
  dataCriacao      DateTime              @default(now())

  contaBancaria ContaBancaria @relation(fields: [contaBancariaId], references: [id])
  conciliacao   Conciliacao?  @relation(fields: [conciliacaoId], references: [id])

  @@map("movimentacoes_bancarias")
}

model Conciliacao {
  id                 String   @id @default(cuid()) @map("_id")
  empresaId          String
  contaBancariaId    String
  periodoIni         DateTime
  periodoFin         DateTime
  dataConciliacao    DateTime @default(now())
  totalCreditos      Float    @default(0)
  totalDebitos       Float    @default(0)
  totalConciliado    Float    @default(0)
  totalNaoConciliado Float    @default(0)
  observacoes        String?

  empresa       Empresa                @relation(fields: [empresaId], references: [id])
  contaBancaria ContaBancaria          @relation(fields: [contaBancariaId], references: [id])
  movimentacoes MovimentacaoBancaria[]

  @@map("conciliacoes")
}

enum TipoContaBancaria {
  CORRENTE
  POUPANCA
  INVESTIMENTO
}

enum TipoMovimentoBancario {
  CREDITO
  DEBITO
}

// =====================================================
// CHEQUES
// =====================================================

model Cheque {
  id              String         @id @default(cuid()) @map("_id")
  empresaId       String
  contaBancariaId String?
  clienteId       String? // cheque de cliente (recebido)
  fornecedorId    String? // cheque próprio (emitido)
  numero          String
  banco           String
  agencia         String
  conta           String
  emitente        String // nome do emitente
  valor           Float
  dataEmissao     DateTime
  dataVencimento  DateTime
  dataCompensacao DateTime?
  tipo            TipoCheque     @default(RECEBIDO) // RECEBIDO, EMITIDO
  situacao        SituacaoCheque @default(EM_CARTEIRA) // EM_CARTEIRA, DEPOSITADO, COMPENSADO, DEVOLVIDO, REPASSADO, CANCELADO
  motivoDevolucao String?
  observacoes     String?
  dataCriacao     DateTime       @default(now())
  dataAtualizacao DateTime       @updatedAt

  empresa       Empresa        @relation(fields: [empresaId], references: [id])
  contaBancaria ContaBancaria? @relation(fields: [contaBancariaId], references: [id])
  cliente       Cliente?       @relation(fields: [clienteId], references: [id])
  fornecedor    Fornecedor?    @relation(fields: [fornecedorId], references: [id])

  @@index([empresaId])
  @@index([situacao])
  @@index([dataVencimento])
  @@map("cheques")
}

enum TipoCheque {
  RECEBIDO
  EMITIDO
}

enum SituacaoCheque {
  EM_CARTEIRA
  DEPOSITADO
  COMPENSADO
  DEVOLVIDO
  REPASSADO
  CANCELADO
}

// =====================================================
// CENTRO DE CUSTO
// =====================================================

model CentroCusto {
