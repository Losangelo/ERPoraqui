  observacoes     String?
  dataCriacao     DateTime @default(now())
  dataAtualizacao DateTime @updatedAt

  empresa  Empresa          @relation(fields: [empresaId], references: [id])
  itens    LicitacaoItem[]

  @@unique([empresaId, numero])
  @@map("licitacoes")
}

model LicitacaoItem {
  id           String   @id @default(cuid()) @map("_id")
  licitacaoId  String
  produtoId    String
  quantidade   Float
  valorUnitario Float
  marca        String?

  licitacao Licitacao @relation(fields: [licitacaoId], references: [id], onDelete: Cascade)
  produto   Produto   @relation(fields: [produtoId], references: [id])

  @@map("licitacoes_itens")
}

// =====================================================
// ADIANTAMENTOS
// =====================================================

model Adiantamento {
  id              String   @id @default(cuid()) @map("_id")
  empresaId       String
  clienteId       String?
  fornecedorId    String?
  funcionarioId   String?
  tipo            String   // CLIENTE | FORNECEDOR | FUNCIONARIO
  valor           Float
  dataAdiantamento DateTime
  dataPrevisao    DateTime?
  situacao        String   @default("ABERTO") // ABERTO | QUITADO | CANCELADO
  formaPagamento  String?  // DINHEIRO | PIX | CARTAO_CREDITO | CARTAO_DEBITO | BOLETO | TRANSFERENCIA | CHEQUE
  observacoes     String?
  dataCriacao     DateTime @default(now())
  dataAtualizacao DateTime @updatedAt

  empresa   Empresa    @relation(fields: [empresaId], references: [id])
  cliente   Cliente?   @relation(fields: [clienteId], references: [id])
  fornecedor Fornecedor? @relation(fields: [fornecedorId], references: [id])

