// =====================================================
// SISTEMA ERP - FilhoDoGuerreiro
// Desenvolvido por: LosAngelo Pacífico (CEO)
// Banco: erp_filho_do_guerreiro
// =====================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =====================================================
// USUÁRIOS E AUTENTICAÇÃO
// =====================================================

model Usuario {
  id              String        @id @default(cuid()) @map("_id")
  empresaId       String
  email           String        @unique
  nome            String
  senha           String
  perfil          PerfilUsuario @default(USUARIO)
  ativo           Boolean       @default(true)
  ultimoAcesso    DateTime?
  dataCriacao     DateTime      @default(now())
  dataAtualizacao DateTime      @updatedAt

  empresa Empresa @relation(fields: [empresaId], references: [id])

  @@map("usuarios")
}

enum PerfilUsuario {
  ADMINISTRADOR
  GERENTE
  USUARIO
  VISUALIZADOR
}

// =====================================================
// EMPRESAS E FILIAIS (Multi-Tenant)
// =====================================================

model Empresa {
  id                 String           @id @default(cuid()) @map("_id")
  razaoSocial        String
  nomeFantasia       String?
  cnpj               String           @unique
  inscricaoEstadual  String?
  inscricaoMunicipal String?
  telefone           String?
  email              String?
  site               String?
  logo               String?
  endereco           Json?
  regimeTributario   RegimeTributario @default(SIMPLES_NACIONAL)
  ativo              Boolean          @default(true)
  dataCriacao        DateTime         @default(now())
  dataAtualizacao    DateTime         @updatedAt

  filiais              Filial[]
  clientes             Cliente[]
  fornecedores         Fornecedor[]
  transportadoras      Transportadora[]
  vendedores           Vendedor[]
  produtos             Produto[]
  pedidosVenda         PedidoVenda[]
  orcamentos           Orcamento[]
  pedidosCompra        PedidoCompra[]
  cotacoesCompra       CotacaoCompra[]
  entradasMercadoria   EntradaMercadoria[]
  movimentacoesEstoque MovimentacaoEstoque[]
  parametros           ParametroSistema[]
  contasReceber        ContaReceber[]
  contasPagar          ContaPagar[]
  fluxoCaixa           FluxoCaixa[]
  cheques              Cheque[]
  centrosCusto         CentroCusto[]
  categorias           Categoria[]
  unidadesMedida       UnidadeMedida[]
  usuarios             Usuario[]
  boletos              Boleto[]
  remessasBoleto       RemessaBoleto[]
  vendasPDV            VendaPDV[]
  operadoresPDV        OperadorPDV[]
  caixas               Caixa[]
  notasFiscais         NotaFiscal[]
  configuracoesNF      ConfiguracaoNF?
  spedFiscais          SpedFiscal[]
  spedContribuicoes    SpedContribuicoes[]
  inventarios          Inventario[]
  contasBancarias      ContaBancaria[]
  conciliacoes         Conciliacao[]
  planoContas          PlanoConta[]
  lancamentosContabeis LancamentoContabil[]
  notasServico         NotaServico[]
  licencas             Licenca[]
  produtoVariacoes     ProdutoVariacao[]
  produtoLotes         ProdutoLote[]
  tabelasPreco         TabelaPreco[]
  spedConfigs          SpedConfig[]
  spedApuracoes        SpedApuracao[]
  veiculos             Veiculo[]
  condutores           Condutor[]
  mdfes                Mdfe[]
  ctes                 Cte[]
  reportTemplates      ReportTemplate[]
  contratos            Contrato[]
  garantias            Garantia[]
  garantiaRegras       GarantiaRegra[]
  devolucoes           Devolucao[]
  convenios            Convenio[]
  licitacoes           Licitacao[]
  promocoes            Promocao[]
  renegociacoes        Renegociacao[]
  adiantamentos        Adiantamento[]
  quitacoes            Quitacao[]
  motoristas           Motorista[]
  veiculosEntrega      VeiculoEntrega[]
  taxasEntrega         TaxaEntrega[]
  entregas             Entrega[]
  avaliacoes           Avaliacao[]

  // Multi-empresa (grupo econômico - empresas vinculadas à mesma licença)
  matrizId           String?
  matriz             Empresa?  @relation("EmpresasGrupo", fields: [matrizId], references: [id])
  empresasVinculadas Empresa[] @relation("EmpresasGrupo")

  @@map("empresas")
}

model Filial {
  id                 String   @id @default(cuid()) @map("_id")
  empresaId          String
  razaoSocial        String
  nomeFantasia       String?
  cnpj               String   @unique
  inscricaoEstadual  String?
  inscricaoMunicipal String?
  telefone           String?
  email              String?
  endereco           Json?
  filialMatriz       Boolean  @default(false)
  numeroNF           Int      @default(1)
  serieNF            String   @default("1")
  ativo              Boolean  @default(true)
  dataCriacao        DateTime @default(now())
  dataAtualizacao    DateTime @updatedAt

  empresa      Empresa       @relation(fields: [empresaId], references: [id])
  pedidosVenda PedidoVenda[]
  orcamentos   Orcamento[]
  vendasPDV    VendaPDV[]
  caixas       Caixa[]
  notasFiscais NotaFiscal[]
  inventarios  Inventario[]
  notasServico NotaServico[]
  mdfes        Mdfe[]
  ctes         Cte[]
  entregas     Entrega[]

  @@map("filiais")
}

enum RegimeTributario {
  SIMPLES_NACIONAL
  LUCRO_PRESUMIDO
  LUCRO_REAL
  ISENTO
}

// =====================================================
// ENDEREÇO (Tipo Embutido) - Removido para PostgreSQL
// =====================================================

// =====================================================
// CLIENTES
// =====================================================

model Cliente {
  id                 String     @id @default(cuid()) @map("_id")
  empresaId          String
  nome               String
  tipoPessoa         TipoPessoa
  documento          String
  inscricaoEstadual  String?
  inscricaoMunicipal String?
  telefone           String?
  telefoneCelular    String?
  email              String?
  endereco           Json?
  dataNascimento     DateTime?
  limiteCredito      Float      @default(0)
  ativo              Boolean    @default(true)
  dataCriacao        DateTime   @default(now())
  dataAtualizacao    DateTime   @updatedAt

  empresa       Empresa        @relation(fields: [empresaId], references: [id])
  pedidosVenda  PedidoVenda[]
  orcamentos    Orcamento[]
  contasReceber ContaReceber[]
  vendasPDV     VendaPDV[]
  notasFiscais  NotaFiscal[]
  notasServico  NotaServico[]
  cheques       Cheque[]
  contratos      Contrato[]
  garantias      Garantia[]
  devolucoes     Devolucao[]
  renegociacoes  Renegociacao[] @relation("ClienteRenegociacao")
  ctesTomador    Cte[]          @relation("CteTomador")
  ctesRemetente  Cte[]          @relation("CteRemetente")
  ctesDestinatario Cte[]        @relation("CteDestinatario")
  convenios      Convenio[]
  adiantamentos  Adiantamento[]
  quitacoes      Quitacao[]
  entregas       Entrega[]

  @@map("clientes")
}

enum TipoPessoa {
  FISICA
  JURIDICA
}

// =====================================================
// FORNECEDORES
// =====================================================

model Fornecedor {
  id                 String     @id @default(cuid()) @map("_id")
  empresaId          String
  nome               String
  tipoPessoa         TipoPessoa
  documento          String
  inscricaoEstadual  String?
  inscricaoMunicipal String?
  telefone           String?
  telefoneCelular    String?
  email              String?
  endereco           Json?
  ativo              Boolean    @default(true)
  dataCriacao        DateTime   @default(now())
  dataAtualizacao    DateTime   @updatedAt

  empresa          Empresa           @relation(fields: [empresaId], references: [id])
  pedidosCompra    PedidoCompra[]
  respostasCotacao RespostaCotacao[]
  contasPagar      ContaPagar[]
  notasFiscais     NotaFiscal[]
  cheques          Cheque[]
  renegociacoes    Renegociacao[] @relation("FornecedorRenegociacao")
  adiantamentos    Adiantamento[]
  quitacoes        Quitacao[]

  @@map("fornecedores")
}

// =====================================================
// TRANSPORTADORAS
// =====================================================

model Transportadora {
  id                 String     @id @default(cuid()) @map("_id")
  empresaId          String
  nome               String
  tipoPessoa         TipoPessoa
  documento          String
  inscricaoEstadual  String?
  inscricaoMunicipal String?
  telefone           String?
  telefoneCelular    String?
  email              String?
  endereco           Json?
  ativo              Boolean    @default(true)
  dataCriacao        DateTime   @default(now())
  dataAtualizacao    DateTime   @updatedAt

  empresa Empresa @relation(fields: [empresaId], references: [id])
  entregas Entrega[]

  @@map("transportadoras")
}

// =====================================================
// VENDEDORES
// =====================================================

model Vendedor {
  id                String     @id @default(cuid()) @map("_id")
  empresaId         String
  nome              String
  tipoPessoa        TipoPessoa
  documento         String
  inscricaoEstadual String?
  telefone          String?
  telefoneCelular   String?
  email             String?
  comissao          Float      @default(0)
  ativo             Boolean    @default(true)
  dataCriacao       DateTime   @default(now())
  dataAtualizacao   DateTime   @updatedAt

  empresa Empresa @relation(fields: [empresaId], references: [id])

  @@map("vendedores")
}

// =====================================================
// PRODUTOS
// =====================================================

model Produto {
  id                 String           @id @default(cuid()) @map("_id")
  empresaId          String
  codigoInterno      String
  codigoBarras       String?
  gtin               String?
  nome               String
  descricao          String?
  descricaoDetalhada String?
  categoriaId        String?
  unidadeMedidaId    String?
  precoVenda         Float
  precoCusto         Float            @default(0)
  precoMinimo        Float            @default(0)
  quantidadeEstoque  Float            @default(0)
  estoqueMinimo      Float            @default(0)
  estoqueMaximo      Float            @default(0)
  pesoBruto          Float?
  pesoLiquido        Float?
  volume             Float?
  ncm                String?
  cest               String?
  origenMercadoria   OrigemMercadoria @default(NACIONAL)
  ativo              Boolean          @default(true)
  dataCriacao        DateTime         @default(now())
  dataAtualizacao    DateTime         @updatedAt

  empresa              Empresa               @relation(fields: [empresaId], references: [id])
  categoria            Categoria?            @relation(fields: [categoriaId], references: [id])
  unidadeMedida        UnidadeMedida?        @relation(fields: [unidadeMedidaId], references: [id])
  itensPedidoVenda     ItemPedidoVenda[]
  itensPedidoCompra    ItemPedidoCompra[]
  itensCotacaoCompra   ItemCotacaoCompra[]
  itensEntrada         ItemEntrada[]
  itensOrcamento       ItemOrcamento[]
  itensVendaPDV        ItemVendaPDV[]
  itensNotaFiscal      ItemNotaFiscal[]
  itensInventario      ItemInventario[]
  movimentacoesEstoque MovimentacaoEstoque[]
  variacoes            ProdutoVariacao[]
  lotes                ProdutoLote[]
  tabelasPreco         TabelaPrecoItem[]
  garantias            Garantia[]
  devolucaoItens       DevolucaoItem[]
  licitacoesItens      LicitacaoItem[]
  promocoesItens       PromocaoItem[]

  @@unique([empresaId, codigoInterno])
  @@map("produtos")
}

model ProdutoVariacao {
  id              String   @id @default(cuid()) @map("_id")
  empresaId       String
  produtoId       String
  sku             String
  nome            String
  valor           String
  precoAdicional  Float    @default(0)
  estoque         Float    @default(0)
  codigoBarras    String?
  ativo           Boolean  @default(true)
  dataCriacao     DateTime @default(now())
  dataAtualizacao DateTime @updatedAt

  empresa Empresa @relation(fields: [empresaId], references: [id])
  produto Produto @relation(fields: [produtoId], references: [id], onDelete: Cascade)

  @@unique([empresaId, produtoId, sku])
  @@map("produto_variacoes")
}

model ProdutoLote {
  id                 String    @id @default(cuid()) @map("_id")
  empresaId          String
  produtoId          String
  codigoLote         String
  dataFabricacao     DateTime?
  dataValidade       DateTime?
  quantidade         Float     @default(0)
  quantidadeOriginal Float     @default(0)
  custoUnitario      Float     @default(0)
  ativo              Boolean   @default(true)
  dataCriacao        DateTime  @default(now())
  dataAtualizacao    DateTime  @updatedAt

  empresa Empresa @relation(fields: [empresaId], references: [id])
  produto Produto @relation(fields: [produtoId], references: [id], onDelete: Cascade)

  @@unique([empresaId, produtoId, codigoLote])
  @@map("produto_lotes")
}

model TabelaPreco {
  id              String   @id @default(cuid()) @map("_id")
  empresaId       String
  nome            String
  descricao       String?
  tipo            String   @default("VISTA")
  markupBase      Float    @default(0)
  ativo           Boolean  @default(true)
  dataCriacao     DateTime @default(now())
  dataAtualizacao DateTime @updatedAt

  empresa Empresa           @relation(fields: [empresaId], references: [id])
  itens   TabelaPrecoItem[]

  @@unique([empresaId, nome])
  @@map("tabelas_preco")
}

model TabelaPrecoItem {
  id              String   @id @default(cuid()) @map("_id")
  tabelaPrecoId   String
  produtoId       String
  precoVenda      Float
  precoMinimo     Float    @default(0)
  descontoMaximo  Float    @default(0)
  dataCriacao     DateTime @default(now())
  dataAtualizacao DateTime @updatedAt

  tabelaPreco TabelaPreco @relation(fields: [tabelaPrecoId], references: [id], onDelete: Cascade)
  produto     Produto     @relation(fields: [produtoId], references: [id])

  @@unique([tabelaPrecoId, produtoId])
  @@map("tabelas_preco_itens")
}

model Promocao {
  id              String   @id @default(cuid()) @map("_id")
  empresaId       String
  nome            String
  descricao       String?
  tipoDesconto    String   @default("PERCENTUAL")
  valorDesconto   Float    @default(0)
  qtdMinima       Int?
  qtdCobrar       Int?
  dataInicio      DateTime
  dataFim         DateTime
  ativo           Boolean  @default(true)
  aplicaProdutos  String   @default("TODOS")
  dataCriacao     DateTime @default(now())
  dataAtualizacao DateTime @updatedAt

  empresa Empresa        @relation(fields: [empresaId], references: [id])
  itens   PromocaoItem[]

  @@map("promocoes")
}

model PromocaoItem {
  id               String @id @default(cuid()) @map("_id")
  promocaoId       String
  produtoId        String
  precoPromocional Float?

  promocao Promocao @relation(fields: [promocaoId], references: [id], onDelete: Cascade)
  produto  Produto  @relation(fields: [produtoId], references: [id])

  @@unique([promocaoId, produtoId])
  @@map("promocoes_itens")
}

enum OrigemMercadoria {
  NACIONAL
  ESTRANGEIRA_IMPORTACAO_DIRETA
  ESTRANGEIRA_NACIONALIZADA
}

model Categoria {
  id              String   @id @default(cuid()) @map("_id")
  empresaId       String
  nome            String
  descricao       String?
  categoriaPaiId  String?
  ativo           Boolean  @default(true)
  dataCriacao     DateTime @default(now())
  dataAtualizacao DateTime @updatedAt

  empresa       Empresa     @relation(fields: [empresaId], references: [id])
  categoriaPai  Categoria?  @relation("CategoriaSubcategorias", fields: [categoriaPaiId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  subcategorias Categoria[] @relation("CategoriaSubcategorias")
  produtos      Produto[]

  @@map("categorias")
}

model UnidadeMedida {
  id              String   @id @default(cuid()) @map("_id")
  empresaId       String
  simbolo         String
  descricao       String
  fracionada      Boolean  @default(false)
  ativo           Boolean  @default(true)
  dataCriacao     DateTime @default(now())
  dataAtualizacao DateTime @updatedAt

  empresa  Empresa   @relation(fields: [empresaId], references: [id])
  produtos Produto[]

  @@unique([empresaId, simbolo])
  @@map("unidades_medida")
}

// =====================================================
// PEDIDOS DE VENDA
// =====================================================

model PedidoVenda {
  id                    String         @id @default(cuid()) @map("_id")
  empresaId             String
  filialId              String
  clienteId             String
  numeroPedido          String
  serie                 String         @default("1")
  tipoOperacao          TipoOperacao   @default(VENDA)
  situacao              SituacaoPedido @default(EM_ABERTO)
  dataEmissao           DateTime?
  dataEntrega           DateTime?
  valorTotal            Float
  valorDesconto         Float          @default(0)
  valorFrete            Float          @default(0)
  valorOutrosAcrescimos Float          @default(0)
  observacoes           String?
  observacoesInternas   String?

  // Condições de pagamento
  condicaoPagamento   String? // A_VISTA, A_PRAZO, PARCELADO
  quantidadeParcelas  Int?    @default(1)
  intervaloParcelas   Int?    @default(30) // dias entre parcelas
  primeiraParcelaDias Int?    @default(0) // dias para primeira parcela

  dataCriacao     DateTime @default(now())
  dataAtualizacao DateTime @updatedAt

  empresa       Empresa           @relation(fields: [empresaId], references: [id])
  filial        Filial            @relation(fields: [filialId], references: [id])
  cliente       Cliente           @relation(fields: [clienteId], references: [id])
  itens         ItemPedidoVenda[]
  contasReceber ContaReceber[]
  orcamento     Orcamento?
  notaFiscal    NotaFiscal?
  devolucoes    Devolucao[]
  entregas      Entrega[]

  @@unique([empresaId, numeroPedido, serie])
  @@map("pedidos_venda")
}

model ItemPedidoVenda {
  id            String   @id @default(cuid()) @map("_id")
  pedidoVendaId String
  produtoId     String
  numeroItem    Int
  quantidade    Float
  unidadeMedida String
  valorUnitario Float
  valorTotal    Float
  valorDesconto Float    @default(0)
  dataCriacao   DateTime @default(now())

  pedidoVenda PedidoVenda @relation(fields: [pedidoVendaId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  produto     Produto     @relation(fields: [produtoId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("itens_pedido_venda")
}

enum TipoOperacao {
  VENDA
  DEVOLUCAO
  CONSIGNACAO
  REMESSA
}

enum SituacaoPedido {
  EM_ABERTO
  CONFIRMADO
  EM_PRODUCAO
  ENVIADO
  ENTREGUE
  CANCELADO
}

// =====================================================
// ORÇAMENTOS DE VENDA
// =====================================================

model Orcamento {
  id                    String            @id @default(cuid()) @map("_id")
  empresaId             String
  filialId              String
  clienteId             String
  numeroOrcamento       String
  serie                 String            @default("1")
  dataValidade          DateTime
  dataEmissao           DateTime?
  valorTotal            Float
  valorDesconto         Float             @default(0)
  valorFrete            Float             @default(0)
  valorOutrosAcrescimos Float             @default(0)
  observacoes           String?
  observacoesInternas   String?
  situacao              SituacaoOrcamento @default(ABERTO)
  pedidoVendaId         String?           @unique
  dataCriacao           DateTime          @default(now())
  dataAtualizacao       DateTime          @updatedAt

  empresa     Empresa         @relation(fields: [empresaId], references: [id])
  filial      Filial          @relation(fields: [filialId], references: [id])
  cliente     Cliente         @relation(fields: [clienteId], references: [id])
  pedidoVenda PedidoVenda?    @relation(fields: [pedidoVendaId], references: [id])
  itens       ItemOrcamento[]

  @@unique([empresaId, numeroOrcamento, serie])
  @@map("orcamentos")
}

model ItemOrcamento {
  id            String   @id @default(cuid()) @map("_id")
  orcamentoId   String
  produtoId     String
  numeroItem    Int
  quantidade    Float
  unidadeMedida String
  valorUnitario Float
  valorTotal    Float
  valorDesconto Float    @default(0)
  dataCriacao   DateTime @default(now())

  orcamento Orcamento @relation(fields: [orcamentoId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  produto   Produto   @relation(fields: [produtoId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("itens_orcamento")
}

enum SituacaoOrcamento {
  ABERTO
  APROVADO
  REPROVADO
  EXPIRADO
  CONVERTIDO
  CANCELADO
}

// =====================================================
// PEDIDOS DE COMPRA
// =====================================================

model PedidoCompra {
  id            String         @id @default(cuid()) @map("_id")
  empresaId     String
  fornecedorId  String
  numeroPedido  String
  serie         String         @default("1")
  tipoOperacao  TipoOperacao   @default(VENDA)
  situacao      SituacaoPedido @default(EM_ABERTO)
  dataEmissao   DateTime?
  dataEntrega   DateTime?
  valorTotal    Float
  valorDesconto Float          @default(0)
  valorFrete    Float          @default(0)
  observacoes   String?

  // Condições de pagamento
  condicaoPagamento   String? // A_VISTA, A_PRAZO, PARCELADO
  quantidadeParcelas  Int?    @default(1)
  intervaloParcelas   Int?    @default(30) // dias entre parcelas
  primeiraParcelaDias Int?    @default(0) // dias para primeira parcela

  dataCriacao     DateTime @default(now())
  dataAtualizacao DateTime @updatedAt

  empresa     Empresa             @relation(fields: [empresaId], references: [id])
  fornecedor  Fornecedor          @relation(fields: [fornecedorId], references: [id])
  itens       ItemPedidoCompra[]
  entradas    EntradaMercadoria[]
  contasPagar ContaPagar[]

  @@unique([empresaId, numeroPedido, serie])
  @@map("pedidos_compra")
}

model ItemPedidoCompra {
  id                 String   @id @default(cuid()) @map("_id")
  pedidoCompraId     String
  produtoId          String
  numeroItem         Int
  quantidade         Float
  quantidadeRecebida Float    @default(0)
  unidadeMedida      String
  valorUnitario      Float
  valorTotal         Float
  valorDesconto      Float    @default(0)
  dataCriacao        DateTime @default(now())

  pedidoCompra PedidoCompra @relation(fields: [pedidoCompraId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  produto      Produto      @relation(fields: [produtoId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("itens_pedido_compra")
}

// =====================================================
// COTAÇÃO DE COMPRAS
// =====================================================

model CotacaoCompra {
  id              String          @id @default(cuid()) @map("_id")
  empresaId       String
  numeroCotacao   String
  serie           String          @default("1")
  situacao        SituacaoCotacao @default(ABERTA)
  dataAbertura    DateTime        @default(now())
  dataValidade    DateTime?
  observacoes     String?
  dataCriacao     DateTime        @default(now())
  dataAtualizacao DateTime        @updatedAt

  empresa   Empresa             @relation(fields: [empresaId], references: [id])
  itens     ItemCotacaoCompra[]
  respostas RespostaCotacao[]

  @@unique([empresaId, numeroCotacao, serie])
  @@map("cotacoes_compra")
}

