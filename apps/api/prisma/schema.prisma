// =====================================================
// NF-e - NOTA FISCAL ELETRÔNICA
// =====================================================

model NotaFiscal {
  id                 String          @id @default(cuid()) @map("_id")
  empresaId          String
  filialId           String
  clienteId          String?
  fornecedorId       String?
  pedidoVendaId      String?         @unique
  tipoDocumento      TipoDocumentoNF
  modelo             ModeloNF        @default(NFE)
  serie              String
  numero             Int
  chaveAcesso        String          @unique
  dataEmissao        DateTime        @default(now())
  dataSaida          DateTime?
  tipoOperacao       TipoOperacaoNF
  finalidadeEmissao  FinalidadeNF    @default(NORMAL)
  naturezaOperacao   String
  valorTotal         Float
  valorDesconto      Float           @default(0)
  valorFrete         Float           @default(0)
  valorSeguro        Float           @default(0)
  valorOutros        Float           @default(0)
  valorBaseICMS      Float           @default(0)
  valorICMS          Float           @default(0)
  valorBaseICMSST    Float           @default(0)
  valorICMSST        Float           @default(0)
  valorPIS           Float           @default(0)
  valorCOFINS        Float           @default(0)
  valorIPI           Float           @default(0)
  valorTotalTributos Float           @default(0)

  // Reforma Tributária 2026 - CBS e IBS
  valorBaseCBS Float @default(0)
  valorCBS     Float @default(0)
  aliquotaCBS  Float @default(0)
  valorBaseIBS Float @default(0)
  valorIBS     Float @default(0)
  aliquotaIBS  Float @default(0)

  // Imposto Seletivo (IS) - produtos específicos
  valorIS    Float @default(0)
  aliquotaIS Float @default(0)

  // Totais reforma tributária
  valorTotalReformaTributaria Float @default(0)

  situacao                  SituacaoNF @default(EM_DIGITACAO)
  statusSefaz               String?
  motivo                    String?
  xmlEnvio                  String?
  xmlRetorno                String?
  protocolo                 String?
  dataProtocolo             DateTime?
  dataAutorizacao           DateTime?
  numeroRecibo              String?
  pdfPath                   String?
  observacoes               String?
  informacoesComplementares String?
  dataCriacao               DateTime   @default(now())
  dataAtualizacao           DateTime   @updatedAt

  empresa     Empresa          @relation(fields: [empresaId], references: [id])
  filial      Filial           @relation(fields: [filialId], references: [id])
  cliente     Cliente?         @relation(fields: [clienteId], references: [id])
  fornecedor  Fornecedor?      @relation(fields: [fornecedorId], references: [id])
  pedidoVenda PedidoVenda?     @relation(fields: [pedidoVendaId], references: [id])
  itens       ItemNotaFiscal[]
  eventos     EventoNF[]

  @@unique([empresaId, modelo, serie, numero])
  @@map("notas_fiscais")
}

model ItemNotaFiscal {
  id                     String  @id @default(cuid()) @map("_id")
  notaFiscalId           String
  produtoId              String?
  numeroItem             Int
  codigo                 String
  descricao              String
  ncm                    String?
  cfop                   String
  unidadeComercial       String
  quantidadeComercial    Float
  valorUnitarioComercial Float
  valorTotalBruto        Float
  valorDesconto          Float   @default(0)
  valorTotalLiquido      Float
  codigoEAN              String?
  codigoTributario       String?
  origemMercadoria       Int     @default(0)
  icmsBaseCalculo        Float   @default(0)
  icmsAliquota           Float   @default(0)
