// =====================================================
// RENEGOCIAÇÃO DE CONTAS
// =====================================================

model Renegociacao {
  id                 String   @id @default(cuid()) @map("_id")
  empresaId          String
  clienteId          String?
  fornecedorId       String?
  tipo               String // RECEBER | PAGAR
  valorTotal         Float
  valorDesconto      Float    @default(0)
  valorJuros         Float    @default(0)
  valorMulta         Float    @default(0)
  valorFinal         Float
  numeroParcelas     Int      @default(1)
  primeiraVencimento DateTime
  situacao           String   @default("PENDENTE") // PENDENTE | CONFIRMADA | CANCELADA
  observacoes        String?
  dataCriacao        DateTime @default(now())
  dataAtualizacao    DateTime @updatedAt

  empresa      Empresa                @relation(fields: [empresaId], references: [id])
  cliente      Cliente?               @relation("ClienteRenegociacao", fields: [clienteId], references: [id])
