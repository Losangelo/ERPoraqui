  tipo        String   @default("FABRICA")
  cobertura   String?
  termos      String?
  ativo       Boolean  @default(true)
  dataCriacao DateTime @default(now())

  empresa Empresa @relation(fields: [empresaId], references: [id])

  @@map("garantia_regras")
}

// =====================================================
// DEVOLUÇÕES / RMA
// =====================================================

enum DevolucaoStatus {
  SOLICITACAO
  INSPECAO
  APROVADO
  REJEITADO
  DESTINADO
  CANCELADO
}

enum DestinoDevolucao {
  REPARO
  SUBSTITUICAO
  CREDITO
  DESCARTE
}

model Devolucao {
  id              String            @id @default(cuid()) @map("_id")
  empresaId       String
  clienteId       String
  pedidoVendaId   String?
  numero          String
  motivo          String // DEFEITO, TROCA, ARREPENDIMENTO, AVARIA
  status          DevolucaoStatus   @default(SOLICITACAO)
  destino         DestinoDevolucao?
  observacoes     String?
  laudoTecnico    String?
  nfDevolucao     String? // NF-e gerada na substituição
  dataCriacao     DateTime          @default(now())
  dataAtualizacao DateTime          @updatedAt

  empresa     Empresa         @relation(fields: [empresaId], references: [id])
  cliente     Cliente         @relation(fields: [clienteId], references: [id])
  pedidoVenda PedidoVenda?    @relation(fields: [pedidoVendaId], references: [id])
  itens       DevolucaoItem[]

  @@unique([empresaId, numero])
  @@map("devolucoes")
}

model DevolucaoItem {
  id          String  @id @default(cuid()) @map("_id")
  devolucaoId String
  produtoId   String
  quantidade  Decimal @default(1) @db.Decimal(10, 2)
  valor       Decimal @default(0) @db.Decimal(12, 2)
  condicao    String  @default("NOVO") // NOVO, DEFEITO, AVARIADO
  numeroSerie String?

  devolucao Devolucao @relation(fields: [devolucaoId], references: [id], onDelete: Cascade)
  produto   Produto   @relation(fields: [produtoId], references: [id])

  @@map("devolucao_itens")
}

// =====================================================
// CONVÊNIOS
// =====================================================

model Convenio {
  id             String   @id @default(cuid()) @map("_id")
  empresaId      String
  clienteId      String
  numero         String
  descricao      String
  dataInicio     DateTime
  dataFim        DateTime?
  valorTotal     Float
  situacao       String   @default("ATIVO") // ATIVO | SUSPENSO | ENCERRADO
  observacoes    String?
  dataCriacao    DateTime @default(now())
  dataAtualizacao DateTime @updatedAt

  empresa Empresa @relation(fields: [empresaId], references: [id])
  cliente Cliente @relation(fields: [clienteId], references: [id])

  @@unique([empresaId, numero])
  @@map("convenios")
}

// =====================================================
// LICITAÇÕES
