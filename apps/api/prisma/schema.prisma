// =====================================================
// QUITAÇÕES
// =====================================================

model Quitacao {
  id              String   @id @default(cuid()) @map("_id")
  empresaId       String
  clienteId       String?
  fornecedorId    String?
  tipo            String   // RECEBER | PAGAR
  valorTotal      Float
  dataQuitacao    DateTime
  formaPagamento  String?
  observacoes     String?
  dataCriacao     DateTime @default(now())
  dataAtualizacao DateTime @updatedAt

  empresa   Empresa          @relation(fields: [empresaId], references: [id])
  cliente   Cliente?         @relation(fields: [clienteId], references: [id])
  fornecedor Fornecedor?     @relation(fields: [fornecedorId], references: [id])
  contas    QuitacaoConta[]

  @@map("quitacoes")
}

model QuitacaoConta {
  id         String @id @default(cuid()) @map("_id")
  quitacaoId String
  contaId    String
  tipoConta  String // RECEBER | PAGAR
  valorPago  Float

  quitacao Quitacao @relation(fields: [quitacaoId], references: [id], onDelete: Cascade)

  @@unique([quitacaoId, contaId, tipoConta])
  @@map("quitacoes_contas")
}

// =====================================================
// SISTEMA DE LICENCIAMENTO
// =====================================================

model Plano {
  id              String       @id @default(cuid()) @map("_id")
  nome            String // BASIC, PROFISSIONAL, PREMIUM
  descricao       String?
  tipoCobranca    TipoCobranca // MENSAL, ANUAL, DEFINITIVO
  precoMensal     Decimal?     @db.Decimal(10, 2)
  precoAnual      Decimal?     @db.Decimal(10, 2)
  precoDefinitivo Decimal?     @db.Decimal(10, 2)

  // Limites
  limiteUsuarios     Int @default(5)
  limiteClientes     Int @default(1000)
  limiteProdutos     Int @default(5000)
  limiteNotasFiscais Int @default(1000) // por mês
  limiteEmpresas     Int @default(1) // empresas no grupo

  // Módulos habilitados
  moduloCrm          Boolean @default(false)
  moduloAutomacao    Boolean @default(false)
  moduloMultiEmpresa Boolean @default(false)
  moduloApi          Boolean @default(false)
  moduloBoletos      Boolean @default(true)
  moduloNfse         Boolean @default(true)
  moduloEcf          Boolean @default(true)
  moduloDre          Boolean @default(true)
  moduloPlanoContas  Boolean @default(true)

  ativo           Boolean  @default(true)
  ordem           Int      @default(0)
  dataCriacao     DateTime @default(now())
  dataAtualizacao DateTime @updatedAt

  licencas Licenca[]

  @@map("planos")
}

enum TipoCobranca {
  MENSAL
  ANUAL
  DEFINITIVO
}

model Licenca {
  id        String @id @default(cuid()) @map("_id")
  empresaId String
  planoId   String

  // Dados da licença
  chave         String        @unique // Chave única de ativação
  tipoCobranca  TipoCobranca
  dataInicio    DateTime
  dataExpiracao DateTime?
  status        StatusLicenca @default(ATIVA)

  // Dados de cobrança
  valorPago       Decimal?  @db.Decimal(10, 2)
  dataPagamento   DateTime?
  codigoTransacao String? // ID da transação (MercadoPago, etc)

  // Limites atuais (podem ser自定义)
  limiteUsuarios     Int?
  limiteClientes     Int?
  limiteProdutos     Int?
  limiteNotasFiscais Int?
  limiteEmpresas     Int? // Limite de empresas no grupo

  // Ativos (valores atuais em uso)
  usuariosAtivos Int @default(0)
  clientesAtivos Int @default(0)
  produtosAtivos Int @default(0)
  notasEsteMes   Int @default(0)

  // Recursos habilitados
  moduloCrm          Boolean @default(false)
  moduloAutomacao    Boolean @default(false)
  moduloMultiEmpresa Boolean @default(false)
  moduloApi          Boolean @default(false)

  dataCriacao     DateTime @default(now())
  dataAtualizacao DateTime @updatedAt

  empresa Empresa      @relation(fields: [empresaId], references: [id])
  plano   Plano        @relation(fields: [planoId], references: [id])
  logs    LicencaLog[]

  @@map("licencas")
}

enum StatusLicenca {
  ATIVA
  EXPIRADA
  CANCELADA
  SUSPENSA
}

model LicencaLog {
  id              String   @id @default(cuid()) @map("_id")
  licencaId       String
  acao            String // ATIVACAO, RENOVACAO, UPGRADE, DOWNGRADE, CANCELAMENTO
  descricao       String?
  planoAnteriorId String?
  planoNovoId     String?
  valor           Decimal? @db.Decimal(10, 2)
  dataCriacao     DateTime @default(now())

  licenca Licenca @relation(fields: [licencaId], references: [id])

  @@map("licencas_log")
}

// =====================================================
// CRM - Customer Relationship Management
// =====================================================

model CRMPipeline {
  id        String  @id @default(cuid()) @map("_id")
  empresaId String
  nome      String
  descricao String?
  cor       String? @default("#3b82f6")
  ordem     Int     @default(0)
  ativo     Boolean @default(true)

  oportunidades CRMOportunidade[]

  @@map("crm_pipelines")
}

model CRMOportunidade {
  id         String  @id @default(cuid()) @map("_id")
  empresaId  String
  pipelineId String
  clienteId  String?

  titulo        String
  descricao     String?
  valor         Decimal @db.Decimal(15, 2)
  probabilidade Int     @default(50)
  estagio       String

  // Quote-to-Cash
  pedidoId     String?
  notaFiscalId String?

  // Controle de tempo
  dataFechamentoEsperado DateTime?
  dataFechamentoReal     DateTime?
  diasNoEstagio          Int       @default(0)

  // Status
  status CRMOportunidadeStatus @default(ABERTA)
  origem String?               @default("manual")

  // Metadados
  dataCriacao     DateTime @default(now())
  dataAtualizacao DateTime @updatedAt
  criadoPor       String?

  pipeline   CRMPipeline                @relation(fields: [pipelineId], references: [id])
  itens      CRMOportunidadeItem[]
  tarefas    CRMTarefa[]
  interacoes CRMInteracao[]
  historico  CRMOportunidadeHistorico[]

  @@map("crm_oportunidades")
}

enum CRMOportunidadeStatus {
  ABERTA
  GANHA
  PERDIDA
  CANCELADA
}

model CRMOportunidadeItem {
  id             String  @id @default(cuid()) @map("_id")
  oportunidadeId String
  produtoId      String?
  produtoNome    String
  quantidade     Decimal @db.Decimal(15, 3)
  precoUnitario  Decimal @db.Decimal(15, 2)
  desconto       Decimal @default(0) @db.Decimal(15, 2)
  total          Decimal @db.Decimal(15, 2)

  oportunidade CRMOportunidade @relation(fields: [oportunidadeId], references: [id], onDelete: Cascade)

  @@map("crm_oportunidade_itens")
}

model CRMOportunidadeHistorico {
  id              String   @id @default(cuid()) @map("_id")
  oportunidadeId  String
  estagioAnterior String?
  estagioNovo     String?
  acao            String // ESTAGIO, STATUS, GANHA, PERDIDA
  descricao       String?
  usuarioId       String?
  dataCriacao     DateTime @default(now())

  oportunidade CRMOportunidade @relation(fields: [oportunidadeId], references: [id], onDelete: Cascade)

  @@map("crm_oportunidade_historico")
}

model CRMTarefa {
  id             String  @id @default(cuid()) @map("_id")
  empresaId      String
  oportunidadeId String?

  titulo     String
  descricao  String?
  tipo       CRMTarefaTipo       @default(OUTRO)
  prioridade CRMTarefaPrioridade @default(MEDIA)

  responsavelId  String?
  dataVencimento DateTime?
  dataConclusao  DateTime?
  concluida      Boolean   @default(false)

  dataCriacao     DateTime @default(now())
  dataAtualizacao DateTime @updatedAt

  oportunidade CRMOportunidade? @relation(fields: [oportunidadeId], references: [id])

  @@map("crm_tarefas")
}

enum CRMTarefaTipo {
  REUNIAO
  LIGACAO
  EMAIL
  VISITA
  DEMONSTRACAO
  PROPOSTA
  OUTRO
}

enum CRMTarefaPrioridade {
  BAIXA
  MEDIA
  ALTA
  URGENTE
}

model CRMInteracao {
  id             String  @id @default(cuid()) @map("_id")
  empresaId      String
  oportunidadeId String?
  clienteId      String?

  tipo      CRMInteracaoTipo
  titulo    String
  descricao String?

  duracaoMinutos Int?
  arquivoUrl     String?

  usuarioId String
  data      DateTime @default(now())

  oportunidade CRMOportunidade? @relation(fields: [oportunidadeId], references: [id])

  @@map("crm_interacoes")
}

enum CRMInteracaoTipo {
  LIGACAO
  EMAIL
  REUNIAO
  WHATSAPP
  VISITA
  DEMONSTRACAO
  OUTRO
}

model CRMCampanha {
  id        String @id @default(cuid()) @map("_id")
  empresaId String

  nome      String
  descricao String?

  tipoSegmento    String?  @default("todos")
  produtoId       String?
  diasInatividade Int?
  valorMinimo     Decimal? @db.Decimal(15, 2)

  status     CRMCampanhaStatus @default(RASCUNHO)
  dataInicio DateTime?
  dataFim    DateTime?

  clientesTarget   Int @default(0)
  enviosRealizados Int @default(0)

  dataCriacao     DateTime @default(now())
  dataAtualizacao DateTime @updatedAt

  @@map("crm_campanhas")
}

enum CRMCampanhaStatus {
  RASCUNHO
  AGENDADA
  ATIVA
  PAUSADA
  FINALIZADA
  CANCELADA
}

// =====================================================
// AUTOMAÇÃO
// =====================================================

model Automacao {
  id        String  @id @default(cuid()) @map("_id")
  empresaId String
  nome      String
  descricao String?

